<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Our Bank | Administration</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background: #f1f5f9; }
        .bank-card { border-radius: 1rem; border: 2px solid #e2e8f0; background: #fff; }
        .nav-admin { background: #0f172a; }
        .stat-card { border-radius: 1rem; border: 2px solid #e2e8f0; transition: transform 0.2s; }
        .stat-card:hover { transform: translateY(-5px); }
    </style>
</head>
<body>

    <nav class="nav-admin p-3 shadow-lg">
        <div class="container d-flex justify-content-between align-items-center">
            <a class="text-white text-decoration-none font-black tracking-tight" href="#">
                <i class="fa-solid fa-user-shield me-2 text-emerald-400"></i>OUR BANK - CENTRE DE CONTRÔLE
            </a>
            <div class="d-flex align-items-center gap-3">
                <span class="text-slate-400 text-xs font-medium">Inspecteur <%= user.prenom %></span>
                <a href="/auth/logout" class="btn btn-outline-danger btn-sm rounded-pill px-3 font-bold"><i class="fa-solid fa-power-off me-1"></i> Déconnexion</a>
            </div>
        </div>
    </nav>

    <div class="container py-5">
        <!-- Bandeau Alerte / Info -->
        <div class="alert bg-slate-900 text-white border-0 p-4 mb-5 d-flex align-items-center justify-content-between">
            <div>
                <i class="fa-solid fa-bell text-emerald-400 me-2"></i> 
                <strong>Système opérationnel.</strong> Aucune anomalie détectée ce jour.
            </div>
            <div class="text-xs opacity-60">Dernière mise à jour : <%= new Date().toLocaleTimeString() %></div>
        </div>

        <!-- Stats Row -->
        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="stat-card p-4 bg-white">
                    <p class="text-[10px] uppercase font-black text-slate-500 mb-1">Total Clients</p>
                    <h2 class="text-3xl font-black text-slate-900"><%= stats.total_clients %></h2>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card p-4 bg-white">
                    <p class="text-[10px] uppercase font-black text-slate-500 mb-1">Comptes Ouverts</p>
                    <h2 class="text-3xl font-black text-emerald-600"><%= stats.total_comptes %></h2>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card p-4 bg-slate-900 text-white">
                    <p class="text-[10px] uppercase font-black text-slate-400 mb-1">Masse Monétaire</p>
                    <h2 class="text-3xl font-black text-emerald-400"><%= parseFloat(stats.total_depots).toFixed(2) %> €</h2>
                </div>
            </div>
        </div>

        <!-- Table Card -->
        <div class="bank-card p-4 shadow-sm">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h6 class="font-black text-slate-700 uppercase tracking-widest">Supervision des Comptes</h6>
                <input type="text" id="searchBar" class="form-control w-25 border-2 border-slate-200" placeholder="Rechercher un titulaire...">
            </div>
            
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="text-slate-400 text-xs uppercase">
                        <tr><th>Titulaire</th><th>Type</th><th>IBAN</th><th class="text-end">Solde</th><th>Statut</th><th class="text-center">Action</th></tr>
                    </thead>
                    <tbody>
                        <% comptes.forEach(compte => { %>
                            <tr>
                                <td class="font-bold text-slate-900"><%= compte.prenom %> <%= compte.nom %></td>
                                <td><span class="badge bg-slate-100 text-slate-600 rounded-full px-3"><%= compte.type_compte %></span></td>
                                <td><code class="text-slate-500"><%= compte.iban %></code></td>
                                <td class="text-end font-mono font-bold text-slate-900"><%= parseFloat(compte.solde).toFixed(2) %> €</td>
                                <td>
                                    <span class="badge <%= compte.statut === 'actif' ? 'bg-emerald-100 text-emerald-700' : 'bg-red-100 text-red-700' %> rounded-full px-3">
                                        <%= compte.statut %>
                                    </span>
                                </td>
                                <td class="text-center">
                                    <form action="/admin/compte/<%= compte.id %>/toggle" method="POST">
                                        <input type="hidden" name="statut_actuel" value="<%= compte.statut %>">
                                        <button type="submit" class="btn btn-sm <%= compte.statut === 'actif' ? 'btn-outline-danger' : 'btn-outline-success' %> rounded-pill px-3 font-bold text-[10px] uppercase">
                                            <%= compte.statut === 'actif' ? 'Bloquer' : 'Débloquer' %>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="py-5 mt-5" style="background-color: #0a2540; color: #ffffff;">
        <div class="container text-center">
            <p class="text-[10px] opacity-60">SÉCURITÉ ET AUDIT BANCAIRE - ESPACE RÉSERVÉ AUX INSPECTEURS</p>
        </div>
    </footer>

    <!-- Script recherche rapide -->
    <script>
        document.getElementById('searchBar').addEventListener('keyup', function(e) {
            const term = e.target.value.toLowerCase();
            const rows = document.querySelectorAll('tbody tr');
            rows.forEach(row => {
                row.style.display = row.innerText.toLowerCase().includes(term) ? '' : 'none';
            });
        });
    </script>
</body>
</html>