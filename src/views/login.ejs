<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0"> <!-- CRUCIAL POUR LE RESPONSIVE -->
    <title>Our Bank | Connexion</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { 
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); 
            min-height: 100vh; 
            display: flex; 
            align-items: center; /* Centrage vertical */
            justify-content: center; /* Centrage horizontal */
            padding: 20px;
        }
        .card-auth { 
            border-radius: 1rem; 
            border: 2px solid #334155;
            background: #ffffff;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.3); 
            width: 100%; /* S'adapte à la largeur du conteneur */
            max-width: 400px; /* Limite la largeur sur grand écran */
        }
        .form-control {
            border: 2px solid #cbd5e1 !important;
            border-radius: 0.5rem;
            padding: 0.75rem 1rem;
            font-weight: 500;
        }
        .form-control:focus {
            border: 2px solid #0f172a !important;
            box-shadow: none !important;
        }
    </style>
</head>
<body>

    <!-- On enlève la grille Bootstrap complexe pour utiliser Flex sur le body -->
    <div class="card-auth p-4 p-md-5">
        <div class="text-center mb-4">
            <h2 class="text-2xl md:text-3xl font-black text-slate-900 tracking-tight">Our Bank</h2>
            <p class="text-slate-500 text-xs md:text-sm mt-2 font-medium">Espace Client Sécurisé</p>
        </div>

        <% if (error) { %>
            <div class="alert alert-danger border-2 border-red-200 bg-red-50 text-red-700 py-2 text-center text-sm mb-4 font-bold"><%= error %></div>
        <% } %>

        <form action="/auth/login" method="POST">
            <div class="mb-4">
                <label class="block text-xs uppercase tracking-widest text-slate-700 font-black mb-2">Adresse Email</label>
                <input type="email" name="email" class="form-control w-100" placeholder="nom@exemple.com" required>
            </div>
            
            <div class="mb-4">
                <label class="block text-xs uppercase tracking-widest text-slate-700 font-black mb-2">Mot de passe</label>
                <input type="password" name="password" class="form-control w-100" placeholder="••••••••" required>
            </div>
            
            <button type="submit" class="btn btn-dark btn-lg w-100 font-bold shadow-lg transition mt-2">Se connecter</button>
        </form>

        <p class="text-center text-slate-500 text-xs md:text-sm mt-4 font-medium">
            Pas de compte ? <a href="/auth/register" class="text-blue-700 font-black underline">Ouvrir un compte</a>
        </p>
    </div>

</body>
</html>