<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Our Bank | Inscription</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { 
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); 
            min-height: 100vh; 
            display: flex; 
            align-items: center; 
            justify-content: center;
            padding: 20px;
        }
        .card-auth { 
            border-radius: 1rem; 
            border: 2px solid #334155; 
            background: #ffffff;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.3); 
            width: 100%;
            max-width: 600px; /* Plus large pour le formulaire */
        }
        .form-control {
            border: 2px solid #cbd5e1 !important;
            border-radius: 0.5rem;
            padding: 0.6rem 1rem;
            font-weight: 500;
        }
        .form-control:focus {
            border: 2px solid #0f172a !important;
            box-shadow: none !important;
        }
    </style>
</head>
<body>

    <div class="card-auth p-4 p-md-5">
        <div class="text-center mb-4">
            <h2 class="text-2xl md:text-3xl font-black text-slate-900 tracking-tight">Devenir Client</h2>
            <p class="text-slate-500 text-xs md:text-sm mt-2 font-medium">Rejoignez Our Bank en quelques clics</p>
        </div>

        <% if (error) { %>
            <div class="alert alert-danger border-2 border-red-200 bg-red-50 text-red-700 py-2 text-center text-sm mb-4 font-bold"><%= error %></div>
        <% } %>

        <form action="/auth/register" method="POST">
            <div class="row">
                <div class="col-12 col-md-6 mb-3">
                    <label class="block text-[10px] uppercase tracking-widest text-slate-700 font-black mb-2">Nom</label>
                    <input type="text" name="nom" class="form-control w-100" required>
                </div>
                <div class="col-12 col-md-6 mb-3">
                    <label class="block text-[10px] uppercase tracking-widest text-slate-700 font-black mb-2">Prénom</label>
                    <input type="text" name="prenom" class="form-control w-100" required>
                </div>
            </div>
            
            <div class="mb-3">
                <label class="block text-[10px] uppercase tracking-widest text-slate-700 font-black mb-2">Email</label>
                <input type="email" name="email" class="form-control w-100" required>
            </div>
            
            <div class="row">
                <div class="col-12 col-md-6 mb-3">
                    <label class="block text-[10px] uppercase tracking-widest text-slate-700 font-black mb-2">Téléphone</label>
                    <input type="text" name="telephone" class="form-control w-100" placeholder="06..." required>
                </div>
                <div class="col-12 col-md-6 mb-3">
                    <label class="block text-[10px] uppercase tracking-widest text-slate-700 font-black mb-2">Date de Naissance</label>
                    <input type="date" name="date_naissance" class="form-control w-100" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="block text-[10px] uppercase tracking-widest text-slate-700 font-black mb-2">Adresse Postale</label>
                <input type="text" name="adresse_postale" class="form-control w-100" required>
            </div>

            <div class="mb-4">
                <label class="block text-[10px] uppercase tracking-widest text-slate-700 font-black mb-2">Mot de passe</label>
                <input type="password" name="password" class="form-control w-100" placeholder="••••••••" required>
                <small class="text-slate-400 font-medium text-[10px]">8+ char, 1 Maj, 1 Chiffre</small>
            </div>

            <button type="submit" class="btn btn-dark btn-lg w-100 font-bold shadow-lg transition mt-2">Créer mon compte</button>
        </form>

        <p class="text-center text-slate-500 text-xs md:text-sm mt-4 font-medium">
            Déjà client ? <a href="/auth/login" class="text-blue-700 font-black underline">Se connecter</a>
        </p>
    </div>

</body>
</html>